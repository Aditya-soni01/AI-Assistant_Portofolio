# =============================================================================
# dev-portfolio — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your actual values.
#
#   cp .env.example .env
#
# IMPORTANT: Never commit your .env file to version control.
# All VITE_ prefixed variables are exposed to the browser bundle.
# Do NOT store secrets that must remain server-side here.
# =============================================================================


# -----------------------------------------------------------------------------
# App Meta (optional — used for SEO / Open Graph tags if implemented)
# -----------------------------------------------------------------------------
VITE_APP_NAME="Your Name | Developer Portfolio"
VITE_APP_URL="https://yourportfolio.dev"


# -----------------------------------------------------------------------------
# EmailJS — Contact Form Integration
# https://www.emailjs.com/
#
# Steps to obtain:
#   1. Create a free account at https://www.emailjs.com/
#   2. Add an Email Service (Gmail, Outlook, etc.) → copy the Service ID
#   3. Create an Email Template → copy the Template ID
#   4. Go to Account → API Keys → copy your Public Key
# -----------------------------------------------------------------------------
VITE_EMAILJS_SERVICE_ID="service_xxxxxxx"
VITE_EMAILJS_TEMPLATE_ID="template_xxxxxxx"
VITE_EMAILJS_PUBLIC_KEY="your_emailjs_public_key"


# -----------------------------------------------------------------------------
# reCAPTCHA v3 (optional — bot protection on the contact form)
# https://www.google.com/recaptcha/admin
#
# Steps to obtain:
#   1. Register your site at https://www.google.com/recaptcha/admin
#   2. Choose reCAPTCHA v3 and add your domain
#   3. Copy the Site Key (public, safe to expose in the browser)
#   NOTE: Never put the Secret Key here — it must stay server-side only.
# -----------------------------------------------------------------------------
VITE_RECAPTCHA_SITE_KEY="your_recaptcha_v3_site_key"


# -----------------------------------------------------------------------------
# Analytics (optional)
# -----------------------------------------------------------------------------

# Google Analytics 4 — Measurement ID
# https://analytics.google.com/
VITE_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Plausible Analytics (privacy-friendly alternative to GA)
# https://plausible.io/
VITE_PLAUSIBLE_DOMAIN="yourportfolio.dev"


# -----------------------------------------------------------------------------
# Formspree (alternative contact form backend — pick ONE service)
# https://formspree.io/
#
# Steps to obtain:
#   1. Create a free account at https://formspree.io/
#   2. Create a new form and copy the form endpoint ID
# -----------------------------------------------------------------------------
VITE_FORMSPREE_ENDPOINT="https://formspree.io/f/your_form_id"


# -----------------------------------------------------------------------------
# GitHub API (optional — for dynamically fetching pinned repos / stats)
# https://docs.github.com/en/rest
#
# A personal access token is only required if you need higher rate limits
# (60 req/hr unauthenticated vs 5,000 req/hr authenticated).
# Scope needed: public_repo (read-only) is sufficient.
# -----------------------------------------------------------------------------
VITE_GITHUB_USERNAME="your_github_username"
VITE_GITHUB_TOKEN="ghp_your_personal_access_token"


# -----------------------------------------------------------------------------
# Dev / Build flags
# -----------------------------------------------------------------------------

# Set to "true" to enable verbose console logging in development
VITE_DEBUG="false"